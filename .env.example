# NovaDev Cloud — Backend .env
# Copy this to .env and fill in values

SECRET_KEY=change-me-32-chars-minimum
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key
KAGGLE_KERNEL_SLUG=novadev-gpu-pool
BACKEND_WEBHOOK_URL=https://absoracode.fanclub.rocks
BACKEND_SECRET=change-me-32-chars-minimum

DATABASE_URL=postgresql+asyncpg://novadev:novadev@localhost/novadev
REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=https://absoracode.fanclub.rocks,http://localhost:3000

FREE_SESSION_MINUTES=30
PAID_SESSION_MINUTES=120
FREE_CONTAINER_SLOTS=30
PAID_CONTAINER_SLOTS=10
MAX_QUEUE_LENGTH=50
IDLE_EXPIRE_MINUTES=5
